  "portsAttributes": {
    "3000": {
      "label": "TRILLIONX app.js core",
      "onAutoForward": "openPreview",
      "visibility": "private"
    },
    "3033": {
      "label": "Hyperbolic Joker Controller",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "3044": {
      "label": "Useful Work Runtime",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "3055": {
      "label": "Exascale-Adjacent Full Runtime",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "3100": {
      "label": "Tier 2/3 Live Dashboard",
      "onAutoForward": "openPreview",
      "visibility": "private"
    },
    "3150": {
      "label": "TRILLIONX 1x10 Master",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "3160": {
      "label": "HBM3e / HAM-RAM Memory Fabric",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "3199": {
      "label": "JSON API Load Test",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "8080": {
      "label": "HTTP Principal",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "8000": {
      "label": "HTTP Alt",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "5000": {
      "label": "API REST",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "9000": {
      "label": "Debug / Profiler",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "9229": {
      "label": "Node Inspector",
      "onAutoForward": "notify",
      "visibility": "private"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "notify",
    "visibility": "private"
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "64gb"
  },
  "containerEnv": {
    "TRILLIONX_TARGET": "TRILLIONX",
    "TRILLIONX_HOST_ROLE": "CODESPACES_SUPPORT_ONLY",
    "TRILLIONX_REAL_ONLY": "true",
    "TRILLIONX_COMPACT_OUTPUT": "1",
    "TRILLIONX_OUTPUT_MAX": "2500",
    "TRX_EXA_WORKERS": "2",
    "TRX_EXA_PACKET": "128",
    "TRX_EXA_TICK_MS": "5000",
    "CXXFLAGS": "-O3 -march=native -mtune=native -flto",
    "CFLAGS": "-O3 -march=native -mtune=native -flto",
    "MAKEFLAGS": "-j4"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cmake-tools",
        "twxs.cmake",
        "ms-vscode.js-debug-nightly"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.scrollback": 2000,
        "terminal.integrated.enablePersistentSessions": false,
        "terminal.integrated.persistentSessionReviveProcess": "never",
        "files.watcherExclude": {
          "**/.git/**": true,
          "**/node_modules/**": true,
          "**/logs/**": true,
          "**/data/**": true,
          "**/history/**": true,
          "**/raid60_plus/**": true,
          "**/memory_fabric/spill/**": true,
          "**/_TRILLIONX_SNAPSHOT_KEEP/**": true,
          "**/*.zip": true
        },
        "search.exclude": {
          "**/node_modules": true,
          "**/logs": true,
          "**/data": true,
          "**/history": true,
          "**/raid60_plus": true,
          "**/memory_fabric/spill": true,
          "**/_TRILLIONX_SNAPSHOT_KEEP": true,
          "**/*.zip": true
        },
        "git.autorefresh": false,
        "git.autofetch": false,
        "git.decorations.enabled": false,
        "extensions.autoUpdate": false,
        "extensions.autoCheckUpdates": false,
        "editor.minimap.enabled": false,
        "typescript.tsserver.maxTsServerMemory": 512,
        "C_Cpp.default.compilerArgs": [
          "-O3",
          "-march=native",
          "-mtune=native"
        ]
      }
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y ca-certificates curl gnupg cmake valgrind nmap htop net-tools iproute2 iputils-ping dnsutils wget jq python3 python3-pip build-essential wabt && curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - && sudo apt-get install -y nodejs && node --version && npm --version && npm install || true",
  "postStartCommand": "echo '✅ TRILLIONX prêt — ports TRILLIONX augmentés' && ss -tulpn | grep LISTEN || true"
}