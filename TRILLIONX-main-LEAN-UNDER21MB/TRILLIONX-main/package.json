    "ports:exact": "node tools/trillionx_ports_process_exact.js",
    "install:exascale-qn-memory": "node TRILLIONX_INSTALL_EXASCALE_QN_MEMORY.js",
    "qn:status": "node -e \"const r=require('./runtime_state/memory/trillionx_exascale_qn_coprocessor_memory_integrated.json'); console.log(JSON.stringify({subject:r.subject,status:r.status,qn:r.qn_coprocessor.active,memory:r.qn_memory.active,digest:r.integrity.digest_short,verdict:r.final_verdict},null,2))\"",
    "install:x10-exascale-qn-parallel": "node TRILLIONX_INSTALL_X10_EXASCALE_QN_PARALLEL_MIRROR.js",
    "x10:status": "node -e \"const r=require('./runtime_state/nodes/trillionx_x10_exascale_qn_parallel_mirror_integrated.json'); console.log(JSON.stringify({subject:r.subject,status:r.status,nodes:r.x10_nodes.count,mirrors_total:r.parallel_mirror.mirrors_total,lanes_per_node:r.parallel_mirror.lanes_per_node,qn_layers_per_node:r.parallel_mirror.qn_layers_per_node,digest:r.integrity.digest_short,verdict:r.final_verdict},null,2))\"",
    "activate:all-new-set": "node TRILLIONX_ACTIVATE_ALL_NEW_SET.js",
    "allnew:status": "node -e \"const r=require('./runtime_state/activation/trillionx_all_new_set_active.json'); console.log(JSON.stringify({subject:r.subject,status:r.status,exascale:r.active_layers.exascale_logic.active,vr:r.active_layers.vr_mirror.active,qn:r.active_layers.qn_coprocessor.active,qn_memory:r.active_layers.qn_memory.active,x10:r.active_layers.x10_nodes.active,nodes:r.active_layers.x10_nodes.node_count,mirrors_total:r.active_layers.parallel_mirror.mirrors_total,digest:r.integrity.digest_short,verdict:r.final_verdict},null,2))\"",
    "network:upgrade": "node TRILLIONX_NETWORK_PORTS_UPGRADE.js",
    "network:status": "node -e \"const r=require('./runtime_state/network/trillionx_network_ports_upgrade.json'); console.log(JSON.stringify({subject:r.subject,status:r.status,port_3000:r.final_verdict.port_3000,recognized_ports:r.network_layers.recognized_ports.count,recognized_processes:r.network_layers.recognized_processes.count,digest:r.integrity.digest_short,verdict:r.final_verdict},null,2))\"",
    "quant:status": "node -e \"const r=require('./runtime_state/quantization/trillionx_exascale_qn_quantization_vr_cache.json'); console.log(JSON.stringify({subject:r.subject,quant_levels:r.qn_quantization.quant_levels,vr_cache_groups:r.vr_cache.groups,vr_cache_lines:r.vr_cache.cache_lines,vr_cache_shards:r.vr_cache.shards,digest:r.integrity.digest_short,verdict:r.final_verdict},null,2))\"",
