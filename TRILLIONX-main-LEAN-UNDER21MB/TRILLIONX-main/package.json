    "fabric:general:full": "node tools/general_fabric_status.js",
    "meta:orchestrate": "node tools/trillionx_meta_orchestrator.js",
    "start:port3000": "bash start_trillionx_port3000.sh",
    "start:safe": "bash start_trillionx_port3000.sh",
    "disk:fabric": "node disk_fabric/trillionx_disk_fabric.js",
    "disk:fabric:full": "node tools/disk_fabric_status.js",
