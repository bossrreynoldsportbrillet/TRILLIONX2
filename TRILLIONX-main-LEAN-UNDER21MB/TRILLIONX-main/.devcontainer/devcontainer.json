  "otherPortsAttributes": {
    "onAutoForward": "notify",
    "visibility": "private"
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "64gb"
  },
  "containerEnv": {
    "TRILLIONX_TARGET": "TRILLIONX",
    "TRILLIONX_HOST_ROLE": "CODESPACES_SUPPORT_ONLY",
    "TRILLIONX_REAL_ONLY": "true",
    "TRILLIONX_COMPACT_OUTPUT": "1",
    "TRILLIONX_OUTPUT_MAX": "2500",
    "TRX_EXA_WORKERS": "2",
    "TRX_EXA_PACKET": "128",
    "TRX_EXA_TICK_MS": "5000",
    "CXXFLAGS": "-O3 -march=native -mtune=native -flto",
    "CFLAGS": "-O3 -march=native -mtune=native -flto",
    "MAKEFLAGS": "-j4",
    "PORT": "3000",
    "TRILLIONX_PORT": "3000",
    "TRILLIONX_STRUCTURE_LOCK": "1",
    "TRILLIONX_REAL_ONLY_OR_UNAVAILABLE": "1",
    "TRILLIONX_MAIN": "app.js",
    "TRILLIONX_NO_DELETE": "1",
    "TRILLIONX_MEMORY_MODE": "VIRTUAL_MIRROR_OF_RECOGNIZED_MEMORY",
    "TRILLIONX_VIRTUAL_MIRROR_RAM_GB": "512",
    "TRILLIONX_VIRTUAL_MIRROR_PROFILE": "DDR5_7200_C26_OCTO_X4_1V1_SAFE",
    "TRILLIONX_CACHE_SYSTEM": "SAFE_BOUNDED_MIRROR",
    "TRILLIONX_RAID60_PLUS": "PACKET_CACHE_GROUPS",
    "TRILLIONX_COPROCESSOR_MODE": "SOFTWARE_FAMILIES_MAPPED_TO_REAL_CPU",
    "TRILLIONX_EXECUTION_MODE": "PERPETUAL_MICRO_PACKET_STREAMING",
    "TRILLIONX_NO_FULL_LOAD": "1",
    "TRILLIONX_MAX_WORKERS": "1",
    "TRILLIONX_MAX_PARALLEL_JOBS": "1",
    "TRILLIONX_CACHE_MAX_MB": "256",
    "TRILLIONX_OUTPUT_LIMIT": "60000",
    "TRILLIONX_HEAVY_BENCH": "0",
    "NODE_OPTIONS": "--max-old-space-size=2048",
    "TRILLIONX_DISK_MODE": "REAL_DISK_PLUS_LOGICAL_RAID60_MIRROR",
    "TRILLIONX_LOGICAL_DISK_GB": "2048",
    "TRILLIONX_DISK_RAID60_PLUS": "LOGICAL_INDEX_ONLY",
    "TRILLIONX_NO_FAKE_DISK": "1",
    "TRILLIONX_PRIORITY_PORT": "3000",
    "TRILLIONX_PROCESS_EXACT": "1",
    "TRILLIONX_PORT_SCAN": "REAL_SS_ONLY",
    "TRILLIONX_PROCESS_SCAN": "REAL_PS_ONLY"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cmake-tools",
        "twxs.cmake",
        "ms-vscode.js-debug-nightly"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.scrollback": 2000,
        "terminal.integrated.enablePersistentSessions": false,
        "terminal.integrated.persistentSessionReviveProcess": "never",
        "files.watcherExclude": {
          "**/.git/**": true,
          "**/node_modules/**": true,
          "**/logs/**": true,
          "**/data/**": true,
          "**/history/**": true,
          "**/raid60_plus/**": true,
          "**/memory_fabric/spill/**": true,
          "**/_TRILLIONX_SNAPSHOT_KEEP/**": true,
          "**/*.zip": true
        },
        "search.exclude": {
          "**/node_modules": true,
          "**/logs": true,
          "**/data": true,
          "**/history": true,
          "**/raid60_plus": true,
          "**/memory_fabric/spill": true,
          "**/_TRILLIONX_SNAPSHOT_KEEP": true,
          "**/*.zip": true
        },
        "git.autorefresh": false,
        "git.autofetch": false,
        "git.decorations.enabled": false,
        "extensions.autoUpdate": false,
        "extensions.autoCheckUpdates": false,
        "editor.minimap.enabled": false,
        "typescript.tsserver.maxTsServerMemory": 512,
        "C_Cpp.default.compilerArgs": [
          "-O3",
          "-march=native",
          "-mtune=native"
        ],
        "trillionx.port": 3000,
        "trillionx.structureLock": true,
        "trillionx.note": "TRILLIONX port 3000 manual system link active",
        "trillionx.realOnlyOrUnavailable": true,
        "trillionx.memoryMode": "VIRTUAL_MIRROR_OF_RECOGNIZED_MEMORY",
        "trillionx.raid60Plus": "PACKET_CACHE_GROUPS",
        "trillionx.executionMode": "PERPETUAL_MICRO_PACKET_STREAMING",
        "trillionx.diskMode": "REAL_DISK_PLUS_LOGICAL_RAID60_MIRROR",
        "trillionx.logicalDiskGb": 2048,
        "trillionx.noFakeDisk": true,
        "trillionx.priorityPort": 3000,
        "trillionx.processExact": true
      }
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y ca-certificates curl gnupg cmake valgrind nmap htop net-tools iproute2 iputils-ping dnsutils wget jq python3 python3-pip build-essential wabt && curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - && sudo apt-get install -y nodejs && node --version && npm --version && npm install || true",
  "postStartCommand": "echo '✅ TRILLIONX prêt — ports TRILLIONX augmentés' && ss -tulpn | grep LISTEN || true"
}
