    "questionnaire:eof-self": "node TRILLIONX_EOF_SELF_QUESTIONNAIRE.js"
  },
  "trillionx": {
    "port": 3000,
    "main": "app.js",
    "mode": "STRUCTURE_LOCK_EXISTING_SYSTEM",
    "real_only_or_unavailable": true,
