  },
  "scripts": {
    "start": "PORT=3000 node app.js",
    "dev": "PORT=3000 node app.js",
    "trillionx": "bash start_trillionx_port3000.sh",
    "start:ram-safe": "PORT=3000 TRILLIONX_RAM_GUARD=1 TRILLIONX_MAX_WORKERS=1 TRILLIONX_MAX_PARALLEL_JOBS=1 TRILLIONX_OUTPUT_LIMIT=60000 TRILLIONX_CACHE_MAX_MB=256 TRILLIONX_HEAVY_BENCH=0 NODE_OPTIONS=--max-old-space-size=2048 node app.js",
    "ram": "node tools/ram_status.js",
    "ports": "ss -lntp | grep -E ':3000|:9229|:2222' || true",
    "ram:512-profile": "node tools/ram_512_profile_status.js",
    "start:512-safe": "bash start_trillionx_512gb_target_safe.sh",
    "ram:mirror512": "node tools/virtual_mirror_ram_status.js",
    "start:mirror512": "bash start_trillionx_virtual_mirror_512_safe.sh",
    "stream:status": "node tools/stream_compute_status.js",
    "stream:app": "node tools/stream_compute_status.js app.js",
    "stream:global": "node tools/global_stream_status.js",
    "stream:perpetual": "node tools/perpetual_stream_status.js",
    "start:perpetual-stream": "bash start_trillionx_perpetual_stream.sh",
    "codespaces:owner": "node tools/codespaces_owner_profile.js",
    "codespaces:safe": "PORT=3000 TRILLIONX_STRUCTURE_LOCK=1 TRILLIONX_NO_DELETE=1 TRILLIONX_REAL_ONLY_OR_UNAVAILABLE=1 TRILLIONX_NO_FULL_LOAD=1 TRILLIONX_MEMORY_MODE=PERPETUAL_STREAM_MICRO_PACKETS TRILLIONX_MAX_WORKERS=1 TRILLIONX_MAX_PARALLEL_JOBS=1 TRILLIONX_CACHE_MAX_MB=256 TRILLIONX_OUTPUT_LIMIT=60000 NODE_OPTIONS=--max-old-space-size=2048 node app.js",
